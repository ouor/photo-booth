{
  "schemaVersion": "1.0.0",
  "metadata": {
    "id": "polaroid-vhs-memory",
    "name": "Polaroid VHS Memory",
    "version": "1.0.0",
    "description": "Classic polaroid card treated with a home-video VHS finish.",
    "tags": ["polaroid", "vhs", "retro"]
  },
  "inputs": [
    {
      "name": "photo",
      "type": "image",
      "label": "Main Photo",
      "required": true,
      "aspectRatio": 1
    },
    {
      "name": "caption",
      "type": "text",
      "label": "Caption",
      "maxLength": 40,
      "placeholder": "Write a short memory"
    }
  ],
  "output": {
    "width": 1080,
    "height": 1350,
    "format": "image/png",
    "backgroundColor": "#ece4db"
  },
  "commands": [
    {
      "op": "createCanvas",
      "id": "canvas",
      "width": 1080,
      "height": 1350,
      "backgroundColor": "#ece4db"
    },
    {
      "op": "drawShape",
      "id": "polaroid-card",
      "shape": "roundRect",
      "x": 120,
      "y": 80,
      "width": 840,
      "height": 1120,
      "style": {
        "fill": "#ffffff",
        "cornerRadius": 24
      }
    },
    {
      "op": "placeImage",
      "id": "photo-layer",
      "source": "photo",
      "x": 160,
      "y": 130,
      "width": 760,
      "height": 760,
      "fit": "cover",
      "angle": -2
    },
    {
      "op": "maskImage",
      "target": "photo-layer",
      "shape": "roundRect",
      "radius": 12
    },
    {
      "op": "drawText",
      "source": "caption",
      "x": 180,
      "y": 950,
      "width": 720,
      "maxLines": 2,
      "ellipsis": true,
      "style": {
        "fontFamily": "Nanum Myeongjo",
        "fontSize": 42,
        "fontWeight": "normal",
        "fill": "#2d2a26",
        "textAlign": "center",
        "lineHeight": 1.3
      }
    },
    {
      "op": "applyAnalogVideo",
      "preset": "vhs-home-video",
      "intensity": 0.82
    },
    {
      "op": "exportImage",
      "format": "image/png",
      "filename": "polaroid-vhs-memory.png"
    }
  ]
}
