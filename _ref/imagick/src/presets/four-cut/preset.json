{
  "schemaVersion": "1.0.0",
  "metadata": {
    "id": "four-cut-classic",
    "name": "Four Cut Classic",
    "version": "1.0.0",
    "description": "Vertical four-cut photo strip with title and footer text.",
    "tags": ["four-cut", "photo-booth", "strip"]
  },
  "inputs": [
    {
      "name": "photo1",
      "type": "image",
      "label": "Cut 1",
      "required": true,
      "aspectRatio": 0.75
    },
    {
      "name": "photo2",
      "type": "image",
      "label": "Cut 2",
      "required": true,
      "aspectRatio": 0.75
    },
    {
      "name": "photo3",
      "type": "image",
      "label": "Cut 3",
      "required": true,
      "aspectRatio": 0.75
    },
    {
      "name": "photo4",
      "type": "image",
      "label": "Cut 4",
      "required": true,
      "aspectRatio": 0.75
    },
    {
      "name": "title",
      "type": "text",
      "label": "Top Title",
      "maxLength": 18,
      "placeholder": "Our Day"
    },
    {
      "name": "footer",
      "type": "text",
      "label": "Bottom Caption",
      "maxLength": 28,
      "placeholder": "2026.04.07"
    }
  ],
  "output": {
    "width": 1080,
    "height": 1920,
    "format": "image/png",
    "backgroundColor": "#111111"
  },
  "commands": [
    {
      "op": "createCanvas",
      "id": "canvas",
      "width": 1080,
      "height": 1920,
      "backgroundColor": "#111111"
    },
    {
      "op": "drawShape",
      "id": "strip-body",
      "shape": "roundRect",
      "x": 250,
      "y": 70,
      "width": 580,
      "height": 1780,
      "style": {
        "fill": "#f8f3ea",
        "cornerRadius": 36
      }
    },
    {
      "op": "drawText",
      "source": "title",
      "x": 300,
      "y": 120,
      "width": 480,
      "maxLines": 1,
      "ellipsis": true,
      "style": {
        "fontFamily": "Pretendard",
        "fontSize": 40,
        "fontWeight": "bold",
        "fill": "#1a1a1a",
        "textAlign": "center"
      }
    },
    {
      "op": "placeImage",
      "id": "cut-1",
      "source": "photo1",
      "x": 315,
      "y": 210,
      "width": 450,
      "height": 300,
      "fit": "cover"
    },
    {
      "op": "maskImage",
      "target": "cut-1",
      "shape": "roundRect",
      "radius": 22
    },
    {
      "op": "placeImage",
      "id": "cut-2",
      "source": "photo2",
      "x": 315,
      "y": 560,
      "width": 450,
      "height": 300,
      "fit": "cover"
    },
    {
      "op": "maskImage",
      "target": "cut-2",
      "shape": "roundRect",
      "radius": 22
    },
    {
      "op": "placeImage",
      "id": "cut-3",
      "source": "photo3",
      "x": 315,
      "y": 910,
      "width": 450,
      "height": 300,
      "fit": "cover"
    },
    {
      "op": "maskImage",
      "target": "cut-3",
      "shape": "roundRect",
      "radius": 22
    },
    {
      "op": "placeImage",
      "id": "cut-4",
      "source": "photo4",
      "x": 315,
      "y": 1260,
      "width": 450,
      "height": 300,
      "fit": "cover"
    },
    {
      "op": "maskImage",
      "target": "cut-4",
      "shape": "roundRect",
      "radius": 22
    },
    {
      "op": "drawText",
      "source": "footer",
      "x": 300,
      "y": 1640,
      "width": 480,
      "maxLines": 1,
      "ellipsis": true,
      "style": {
        "fontFamily": "Pretendard",
        "fontSize": 30,
        "fontWeight": "normal",
        "fill": "#2c2c2c",
        "textAlign": "center"
      }
    },
    {
      "op": "exportImage",
      "format": "image/png",
      "filename": "four-cut-classic.png"
    }
  ]
}
